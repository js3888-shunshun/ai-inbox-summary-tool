# ---- App ----
# Public base URL of this service (the VM's public IP or domain, HTTPS in prod).
# Used to build the OAuth callback and webhook URLs registered with Nylas.
PUBLIC_BASE_URL=http://135.148.170.25:3000
PORT=3000
HOST=0.0.0.0

# Path to the SQLite database file.
DATABASE_PATH=./data/app.db

# ---- Nylas ----
# From your Nylas dashboard (https://dashboard-v3.nylas.com).
NYLAS_API_KEY=nyk_v0_xxx
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_CLIENT_ID=your-nylas-application-client-id
# Secret used to verify the x-nylas-signature HMAC on webhook payloads
# (Nylas shows this when you create the webhook).
NYLAS_WEBHOOK_SECRET=your-webhook-signing-secret

# ---- LLM (Anthropic / Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxx
# Cheap+fast: claude-haiku-4-5-20251001 | Stronger: claude-sonnet-4-6
LLM_MODEL=claude-haiku-4-5-20251001
